"""
================================================================================
Simulation-Informed Deep Learning for Estimating Material Parameters
from Microstructural Morphology

Authors  : Asfandyar Khan, Amir Abbas Kazemzadeh, Mahmood Mamivand

Description
-----------
This script trains a simulation-informed CNN-based regression model to infer
the gradient-energy coefficient (kappa) and an effective mobility parameter (M)
from 2D grayscale microstructure images generated by a Cahn–Hilliard phase-field
model of Fe–Cr spinodal decomposition at 500 °C (773 K).

Pipeline
--------
1. Load labeled dataset (image, kappa, M) from CSV
2. Extract features using a frozen EfficientNetB7 backbone truncated at layer 464
3. Apply Global Average Pooling + Global Max Pooling and concatenate features
4. Perform a stratified 70/10/20 train/validation/test split
5. Standardize features using training-set statistics only
6. Train a multi-task regression head for kappa and M
7. Evaluate on held-out test data using R2, MAE, and parity plots
8. Predict kappa and M for an experimental HAADF-STEM-based image

Notes
-----
- The pooled feature vector dimension is 2688 for the selected layer.
- The experimental image is treated as a morphology-based proxy.
- Full repository details, citation information, and usage instructions should
  be added in the GitHub README.

Reproducibility
---------------
Global seed : 26
Split seed  : 26
TensorFlow deterministic ops enabled when available
================================================================================
"""

# ==============================================================================
# SECTION 0 — REPRODUCIBILITY (must be set before any other imports)
# ==============================================================================

import os

SEED = 26

os.environ["PYTHONHASHSEED"]          = str(SEED)
os.environ["TF_DETERMINISTIC_OPS"]    = "1"
os.environ["TF_CUDNN_DETERMINISTIC"]  = "1"
os.environ["NVIDIA_TF32_OVERRIDE"]    = "0"
os.environ["OMP_NUM_THREADS"]         = "1"
os.environ["TF_NUM_INTRAOP_THREADS"]  = "1"
os.environ["TF_NUM_INTEROP_THREADS"]  = "1"


# ==============================================================================
# SECTION 1 — IMPORTS
# ==============================================================================

import sys
import time
import pickle

import numpy as np
import pandas as pd
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt

import tensorflow as tf

tf.keras.utils.set_random_seed(SEED)

try:
    tf.config.experimental.enable_op_determinism(True)
except Exception:
    print("[WARN] Determinism flag not available in this TF version.")

tf.config.threading.set_intra_op_parallelism_threads(1)
tf.config.threading.set_inter_op_parallelism_threads(1)

from tensorflow.keras.models import Model
from tensorflow.keras.layers import (
    Dense, BatchNormalization, Dropout, Activation, Input,
    GlobalAveragePooling2D, GlobalMaxPooling2D, Concatenate
)
from tensorflow.keras.callbacks import ModelCheckpoint, ReduceLROnPlateau, EarlyStopping
from tensorflow.keras.applications import EfficientNetB7, imagenet_utils
from tensorflow.keras.preprocessing.image import load_img, img_to_array

from sklearn.model_selection import train_test_split
